# ============================================================
# VastraSilai AI Backend — Environment Variables
# Copy this file to .env and fill in your real values
# ============================================================

# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-public-key

# ── WhatsApp (Twilio or Meta Cloud API) ───────────────────
# Uncomment and fill when integrating WhatsApp chatbot
# TWILIO_ACCOUNT_SID=your-twilio-sid
# TWILIO_AUTH_TOKEN=your-twilio-token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Meta WhatsApp Business API ────────────────────────────
# META_WHATSAPP_TOKEN=your-meta-token
# META_PHONE_NUMBER_ID=your-phone-number-id
# WHATSAPP_VERIFY_TOKEN=vastrasilai_verify_token
